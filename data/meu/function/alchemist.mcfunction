clear @p

item replace entity @s armor.head with minecraft:diamond_helmet
item replace entity @s armor.chest with minecraft:golden_chestplate
item replace entity @s armor.legs with minecraft:golden_leggings
item replace entity @s armor.feet with minecraft:golden_boots

item replace entity @s hotbar.0 with minecraft:golden_shovel
item replace entity @s hotbar.1 with minecraft:golden_apple
item replace entity @s hotbar.2 with minecraft:splash_potion[potion_contents={potion:regeneration}]
item replace entity @s hotbar.3 with minecraft:splash_potion[potion_contents={potion:harming}]
item replace entity @s hotbar.4 with minecraft:splash_potion[potion_contents={potion:harming}]
item replace entity @s hotbar.5 with minecraft:lingering_potion[potion_contents={potion:turtle_master}]
item replace entity @s hotbar.6 with minecraft:lingering_potion[potion_contents={potion:poison}]
item replace entity @s hotbar.7 with minecraft:lingering_potion[potion_contents={potion:poison}]
item replace entity @s hotbar.8 with minecraft:melon_slice 14

scoreboard players set @s alchemist 0